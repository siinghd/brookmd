{
  "name": "brookmd-react-native",
  "version": "0.1.3",
  "description": "Streaming markdown for React Native. Rust core over uniffi (JSI TurboModule), incremental parse, RN-native renderer.",
  "author": "siinghd",
  "license": "MIT",
  "homepage": "https://md.hsingh.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siinghd/brookmd.git",
    "directory": "packages/brookmd-react-native"
  },
  "bugs": {
    "url": "https://github.com/siinghd/brookmd/issues"
  },
  "keywords": [
    "react-native",
    "markdown",
    "streaming",
    "rust",
    "uniffi",
    "turbomodule",
    "jsi",
    "llm",
    "ai",
    "ios",
    "android"
  ],
  "source": "./src/index.tsx",
  "main": "./src/index.tsx",
  "module": "./src/index.tsx",
  "react-native": "./src/index.tsx",
  "types": "./src/index.tsx",
  "files": [
    "src",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "ubrn.config.yaml",
    "README.md",
    "!**/__tests__",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!android/build",
    "!ios/build",
    "!**/.*"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "ubrn:generate": "cd ../../crates/brookmd-ffi && ubrn generate jsi bindings --library target/release/libbrook_md_ffi.a --crate brook_md_ffi --ts-dir ../../packages/brookmd-react-native/src/generated --cpp-dir ../../packages/brookmd-react-native/cpp/generated",
    "build:android": "bash scripts/build-android.sh",
    "build:ios": "bash scripts/build-ios.sh"
  },
  "dependencies": {
    "@ubjs/core": "0.31.0-3",
    "brookmd": "^0.23.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.76",
    "uniffi-bindgen-react-native": "0.31.0-3"
  },
  "peerDependenciesMeta": {
    "uniffi-bindgen-react-native": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^18.3.12",
    "@types/react-test-renderer": "^18.3.0",
    "react": "^18.3.1",
    "react-test-renderer": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "codegenConfig": {
    "name": "RNBrookMdReactNativeSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.brookmdreactnative"
    },
    "outputDir": {
      "ios": "ios/generated",
      "android": "android/generated"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
